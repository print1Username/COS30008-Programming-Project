{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "cmake -S . -B build -G \"MinGW Makefiles\" -DCMAKE_BUILD_TYPE=Debug -DCMAKE_C_COMPILER=C:/msys64/ucrt64/bin/gcc.exe -DCMAKE_CXX_COMPILER=C:/msys64/ucrt64/bin/g++.exe -DCMAKE_MAKE_PROGRAM=C:/msys64/ucrt64/bin/mingw32-make.exe",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake Build (Debug)",
      "type": "shell",
      "command": "cmake --build build --config Debug",
      "dependsOn": "CMake Configure",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "Run",
      "type": "shell",
      "command": "${workspaceFolder}\\build\\bin\\COS30008_Programming_Project.exe",
      "dependsOn": "CMake Build (Debug)",
      "problemMatcher": []
    },
    {
      "type": "cppbuild",
      "label": "C/C++: g++.exe build active file",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ]
}